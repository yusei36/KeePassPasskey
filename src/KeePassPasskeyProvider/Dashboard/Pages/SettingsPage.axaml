<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:KeePassPasskeyProvider.Dashboard.ViewModel"
			 xmlns:utils="using:KeePassPasskeyProvider.Dashboard.Utils"
             x:Class="KeePassPasskeyProvider.Dashboard.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="16 16 16 4">
            <TextBlock Text="Settings"
                       Theme="{StaticResource TitleTextBlockStyle}" />
            <Button Grid.Column="1"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    ToolTip.Tip="Save settings"
                    VerticalAlignment="Center"
                    Classes="accent">
                <ui:SymbolIcon Symbol="Save" FontSize="18" />
            </Button>
        </Grid>
        <ScrollViewer Grid.Row="1">
        <StackPanel Spacing="8" Margin="16 8 16 16">

            <ui:SettingsExpander Header="Appearance"
                                 IconSource="DarkTheme"
                                 Description="Application appearance and theme">
                <ui:SettingsExpander.Footer>
                    <ComboBox SelectedItem="{Binding Theme}"
                              ItemsSource="{Binding Themes}"
                              MinWidth="120" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="User Verification"
                                 IconSource="OtherUser"
                                 Description="Require proof of identity before passkey operations"
                                 IsExpanded="True">

                <ui:SettingsExpanderItem Content="Registration"
                                         Description="How users confirm identity when registering a new passkey">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding RegistrationVerification}"
                                  ItemsSource="{Binding VerificationModes}"
                                  MinWidth="160" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Sign-in"
                                         Description="How users confirm identity when signing in with a passkey">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding SignInVerification}"
                                  ItemsSource="{Binding VerificationModes}"
                                  MinWidth="160" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Notification timeout"
                                         Description="How long to wait for the user to approve a notification">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding NotificationTimeoutSeconds}"
                                      Minimum="5"
                                      Maximum="300"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

            <ui:SettingsExpander Header="Notifications"
                                 IconSource="Mail"
                                 Description="Show a system notification when a passkey error occurs">
                <ui:SettingsExpander.Footer>
                    <ToggleSwitch IsChecked="{Binding ShowErrorNotifications}"
                                  OnContent="On"
                                  OffContent="Off"
                                  Margin="0 0 4 0" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="Advanced"
                                 IconSource="Setting"
                                 Description="Timing, resilience and logging settings"
                                 IsExpanded="False">

                <ui:SettingsExpanderItem Content="Log level"
                                         Description="Verbosity of the provider and plugin log files">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding LogLevel}"
                                  ItemsSource="{Binding LogLevels}"
                                  MinWidth="120" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Status refresh interval"
                                         Description="How often the app polls for provider status">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding StatusRefreshIntervalSeconds}"
                                      Minimum="1"
                                      Maximum="3600"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

				<ui:SettingsExpanderItem Content="Credential sync interval"
                                         Description="How often passkey metadata are synced from KeePass to the Windows credential cache.&#10;Set to 0 to disable.">
					<ui:SettingsExpanderItem.Footer>
						<ui:NumberBox Value="{Binding CredentialSyncIntervalSeconds}"
                                      Minimum="0"
                                      Maximum="3600"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
					</ui:SettingsExpanderItem.Footer>
				</ui:SettingsExpanderItem>
				
                <ui:SettingsExpanderItem Content="Max credential cache sync retries"
                                         Description="Background sync pauses after this many failures and resumes on the next passkey request">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding CredentialSyncShutdownThreshold}"
                                      Minimum="1"
                                      Maximum="100"
                                      SmallChange="1"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

            <ui:SettingsExpander Header="About"
                                 IconSource="Help"
                                 Description="Version, source code and license"
                                 IsExpanded="False">

                <ui:SettingsExpanderItem Content="Copyright"
                                         Description="&#169; 2026 Uwe K&#246;gel" />

                <ui:SettingsExpanderItem Content="Version"
                                         Description="{Binding AppVersion}">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding AppVersionFull}"
                                ToolTip.Tip="Copy version">
                            <ui:SymbolIcon Symbol="Copy" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Website"
                                         Description="keepasspasskey.github.io">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://keepasspasskey.github.io"
                                ToolTip.Tip="Open website">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Source code"
                                         Description="github.com/yusei36/KeePassPasskey">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://github.com/yusei36/KeePassPasskey"
                                ToolTip.Tip="Open source code on GitHub">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Report a bug"
                                         Description="github.com/yusei36/KeePassPasskey/issues">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://github.com/yusei36/KeePassPasskey/issues"
                                ToolTip.Tip="Open issue tracker on GitHub">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="License"
                                         Description="GNU General Public License v3.0">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://www.gnu.org/licenses/gpl-3.0.html"
                                ToolTip.Tip="Open license text">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
    </Grid>

</UserControl>
