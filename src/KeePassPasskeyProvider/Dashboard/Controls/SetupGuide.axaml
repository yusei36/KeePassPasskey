<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KeePassPasskeyProvider.Dashboard.Controls.SetupGuide">
    <Expander IsExpanded="{Binding IsSetupExpanded, Mode=TwoWay}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Setup guide" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
        </Expander.Header>

        <StackPanel Margin="4 4 4 8">
            <!-- Step 1 -->
            <Grid ColumnDefinitions="28,*" ColumnSpacing="12" Margin="0 10 0 10">
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0 1 0 0">
                    <TextBlock Text="1" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Install the plugin" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Copy the " />
                        <Run Text="KeePassPasskeyPlugin" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text=" folder into your KeePass " />
                        <Run Text="Plugins" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text=" folder and restart KeePass." />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" />

            <!-- Step 2 -->
            <Grid ColumnDefinitions="28,*" ColumnSpacing="12" Margin="0 10 0 10">
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0 1 0 0">
                    <TextBlock Text="2" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Text="Open Advanced Passkey Options" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Go to " />
                        <Run Text="Settings › Accounts › Passkeys › Advanced options" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text=", or use the button below." />
                    </TextBlock>
                    <Button Content="Advanced Passkey Options"
                            Command="{Binding OpenPasskeySettingsCommand}"
                            Padding="6 2" FontSize="12" HorizontalAlignment="Left" />
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" />

            <!-- Step 3 -->
            <Grid ColumnDefinitions="28,*" ColumnSpacing="12" Margin="0 10 0 10">
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0 1 0 0">
                    <TextBlock Text="3" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Enable KeePassPasskey" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Toggle " />
                        <Run Text="KeePassPasskey" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text=" on in the passkey provider list." />
                    </TextBlock>
                </StackPanel>
            </Grid>

            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" />

            <!-- Step 4 -->
            <Grid ColumnDefinitions="28,*" ColumnSpacing="12" Margin="0 10 0 4">
                <Border Grid.Column="0" Width="24" Height="24" CornerRadius="12"
                        Background="{DynamicResource ControlFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0 1 0 0">
                    <TextBlock Text="4" FontSize="12" FontWeight="SemiBold" Opacity="0.7"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock Text="Verify" FontWeight="SemiBold" FontSize="13" />
                    <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                        <Run Text="Both statuses above should read " />
                        <Run Text="Enabled" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text=" / " />
                        <Run Text="Running" FontFamily="Consolas,Courier New,monospace" FontWeight="SemiBold" />
                        <Run Text="." />
                    </TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Expander>
</UserControl>
