<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:KeePassPasskeyProvider.App.ViewModel"
			 xmlns:utils="using:KeePassPasskeyProvider.App.Utils"
             xmlns:conv="using:KeePassPasskeyProvider.App.Converters"
             x:Class="KeePassPasskeyProvider.App.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             x:CompileBindings="True">

    <Grid RowDefinitions="Auto,*">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto,Auto" Margin="16 16 16 4">
            <TextBlock Text="Settings"
                       Theme="{StaticResource TitleTextBlockStyle}" />
            <ui:SymbolIcon Grid.Column="1" Symbol="ImportantFilled" FontSize="16"
                           VerticalAlignment="Center" Margin="0 0 8 0"
                           IsVisible="{Binding HasUnsavedChanges}"
                           Foreground="{DynamicResource SystemFillColorCautionBrush}"
                           ToolTip.Tip="You have unsaved changes" />
            <Button Grid.Column="2"
                    Command="{Binding ResetCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    IsVisible="{Binding HasUnsavedChanges}"
                    ToolTip.Tip="Discard changes"
                    VerticalAlignment="Center"
                    Margin="0 0 4 0">
                <ui:SymbolIcon Symbol="Undo" FontSize="18" />
            </Button>
			<Button Grid.Column="3"
                    Command="{Binding ResetToDefaultsCommand}"
                    IsEnabled="{Binding !IsSaving}"
                    IsVisible="{Binding CanResetToDefaults}"
                    ToolTip.Tip="Reset to defaults"
                    VerticalAlignment="Center"
                    Margin="0 0 4 0">
				<PathIcon Width="18" Height="18"
						  Data="M11.197 2.43934C11.7828 1.85355 12.7326 1.85355 13.3184 2.43934L17.561 6.68198C18.1468 7.26777 18.1468 8.21751 17.561 8.8033L9.36408 17.0002H14.5001C14.7763 17.0002 15.0001 17.2241 15.0001 17.5002C15.0001 17.7764 14.7763 18.0002 14.5001 18.0002H7.81974C7.40996 18.0217 6.99303 17.876 6.68003 17.5629L2.43739 13.3203C1.8516 12.7345 1.8516 11.7848 2.43739 11.199L11.197 2.43934ZM9.7811 15.169L4.83135 10.2192L3.14449 11.9061C2.94923 12.1014 2.94923 12.4179 3.14449 12.6132L7.38713 16.8558C7.5824 17.0511 7.89898 17.0511 8.09424 16.8558L9.7811 15.169Z" />
			</Button>
            <Button Grid.Column="4"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding CanSave}"
                    ToolTip.Tip="Save settings"
                    VerticalAlignment="Center"
                    Classes="accent">
                <ui:SymbolIcon Symbol="Save" FontSize="18" />
            </Button>
        </Grid>
        <ScrollViewer Grid.Row="1">
        <StackPanel Spacing="8" Margin="16 8 16 16">

            <ui:SettingsExpander Header="Appearance"
                                 IconSource="DarkTheme"
                                 Description="Application appearance and theme">
                <ui:SettingsExpander.Footer>
                    <ComboBox SelectedItem="{Binding Theme}"
                              ItemsSource="{Binding Themes}"
                              MinWidth="120" />
                </ui:SettingsExpander.Footer>
            </ui:SettingsExpander>

            <ui:SettingsExpander Header="Notifications &amp; User Verification"
                                 IconSource="OtherUser"
                                 Description="Notification behavior and user verification for passkey operations"
                                 IsExpanded="True">

                <ui:SettingsExpanderItem Content="Error notifications"
                                         Description="Show a detailed notification when a passkey error occurs (Windows always displays a generic error)">
                    <ui:SettingsExpanderItem.Footer>
                        <ToggleSwitch IsChecked="{Binding ShowErrorNotifications}"
                                      OnContent="On"
                                      OffContent="Off"
                                      Margin="0 0 4 0" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Registration"
                                         Description="Behaviour when creating a passkey">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding RegistrationVerification}"
                                  ItemsSource="{Binding VerificationModes}"
                                  MinWidth="160">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static conv:UserVerificationModeConverters.Text}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Sign-in"
                                         Description="Behaviour when using a passkey">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding SignInVerification}"
                                  ItemsSource="{Binding VerificationModes}"
                                  MinWidth="160">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={x:Static conv:UserVerificationModeConverters.Text}}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Approval timeout"
                                         Description="How long the approval notification stays open">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding NotificationTimeoutSeconds}"
                                      Minimum="5"
                                      Maximum="300"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

<ui:SettingsExpander Header="Advanced"
                                 IconSource="Setting"
                                 Description="Timing, resilience and logging settings"
                                 IsExpanded="False">

                <ui:SettingsExpanderItem Content="Log level"
                                         Description="Verbosity of the provider and plugin log files">
                    <ui:SettingsExpanderItem.Footer>
                        <ComboBox SelectedItem="{Binding LogLevel}"
                                  ItemsSource="{Binding LogLevels}"
                                  MinWidth="120" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Status refresh interval"
                                         Description="How often the app polls for provider status">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding StatusRefreshIntervalSeconds}"
                                      Minimum="1"
                                      Maximum="3600"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

				<ui:SettingsExpanderItem Content="Credential sync interval"
                                         Description="How often passkey metadata are synced from KeePass to the Windows credential cache.&#10;Set to 0 to disable.">
					<ui:SettingsExpanderItem.Footer>
						<ui:NumberBox Value="{Binding CredentialSyncIntervalSeconds}"
                                      Minimum="0"
                                      Maximum="3600"
                                      SmallChange="5"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120"
									  NumberFormatter="{x:Static utils:NumberFormatters.Seconds}" />
					</ui:SettingsExpanderItem.Footer>
				</ui:SettingsExpanderItem>
				
                <ui:SettingsExpanderItem Content="Max credential cache sync retries"
                                         Description="Background sync pauses after this many failures and resumes on the next passkey request">
                    <ui:SettingsExpanderItem.Footer>
                        <ui:NumberBox Value="{Binding CredentialSyncShutdownThreshold}"
                                      Minimum="1"
                                      Maximum="100"
                                      SmallChange="1"
                                      ValidationMode="InvalidInputOverwritten"
                                      SpinButtonPlacementMode="Inline"
                                      MinWidth="120" />
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

            <ui:SettingsExpander Header="About"
                                 IconSource="Help"
                                 Description="Version, source code and license"
                                 IsExpanded="False">

                <ui:SettingsExpanderItem Content="Copyright"
                                         Description="&#169; 2026 Uwe K&#246;gel" />

                <ui:SettingsExpanderItem Content="Version"
                                         Description="{Binding AppVersion}">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding AppVersionFull}"
                                ToolTip.Tip="Copy version">
                            <ui:SymbolIcon Symbol="Copy" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Website"
                                         Description="keepasspasskey.github.io">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://keepasspasskey.github.io"
                                ToolTip.Tip="Open website">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Source code"
                                         Description="github.com/yusei36/KeePassPasskey">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://github.com/yusei36/KeePassPasskey"
                                ToolTip.Tip="Open source code on GitHub">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Report a bug"
                                         Description="github.com/yusei36/KeePassPasskey/issues">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenUrlCommand}"
                                CommandParameter="https://github.com/yusei36/KeePassPasskey/issues"
                                ToolTip.Tip="Open issue tracker on GitHub">
                            <ui:SymbolIcon Symbol="Globe" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="License"
                                         Description="GNU General Public License v3.0"
                                         IsVisible="{Binding HasLicense}">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenLicenseCommand}"
                                ToolTip.Tip="Open license text">
                            <ui:SymbolIcon Symbol="Document" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

                <ui:SettingsExpanderItem Content="Third-party notices"
                                         Description="Open source licenses for bundled libraries"
                                         IsVisible="{Binding HasThirdPartyNotices}">
                    <ui:SettingsExpanderItem.Footer>
                        <Button Command="{Binding OpenThirdPartyNoticesCommand}"
                                ToolTip.Tip="Open third-party notices">
                            <ui:SymbolIcon Symbol="Document" FontSize="14" />
                        </Button>
                    </ui:SettingsExpanderItem.Footer>
                </ui:SettingsExpanderItem>

            </ui:SettingsExpander>

        </StackPanel>
    </ScrollViewer>
    </Grid>

</UserControl>
