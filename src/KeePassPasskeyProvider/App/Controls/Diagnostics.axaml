<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             x:Class="KeePassPasskeyProvider.App.Controls.Diagnostics">
    <Expander IsExpanded="{Binding IsLogVisible, Mode=TwoWay}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Diagnostics" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
        </Expander.Header>

        <StackPanel>
			<!-- Version mismatch warning -->
			<ui:InfoBar Title="Version mismatch"
						Severity="Error"
						IsOpen="{Binding IsVersionMismatch}"
						IsClosable="False" />
			
            <!-- Versions strip -->
            <Border Padding="4 12 0 12"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0 0 0 1">
                <StackPanel Spacing="6">
                    <!-- Provider version row -->
                    <Grid ColumnDefinitions="180,*,28" ColumnSpacing="12" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="KeePassPasskeyProvider"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8 4">
							<SelectableTextBlock Text="{Binding ClientVersionShort}"
                                                 FontFamily="Consolas,Courier New,monospace"
                                                 FontSize="11.5" Opacity="0.7" />
                        </Border>
                        <Button Grid.Column="2"
                                Padding="4"
                                Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding ClientVersion}"
                                ToolTip.Tip="Copy provider version">
                            <ui:SymbolIcon Symbol="Copy" FontSize="14" />
                        </Button>
                    </Grid>

					<!-- Plugin version row -->
					<Grid ColumnDefinitions="180,*,28" ColumnSpacing="12" VerticalAlignment="Center">
						<TextBlock Grid.Column="0"
                                   Text="KeePassPasskeyPlugin"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
						<Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8 4">
							<Panel>
								<SelectableTextBlock Text="{Binding ServerVersionShort}"
                                                     FontFamily="Consolas,Courier New,monospace"
                                                     FontSize="11.5" Opacity="0.7"
                                                     IsVisible="{Binding IsServerVersionAvailable}" />
								<TextBlock Text="not running"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="11.5" Opacity="0.35"
                                           IsVisible="{Binding IsServerVersionNotAvailable}" />
							</Panel>
						</Border>
						<Button Grid.Column="2"
                                Padding="4"
                                Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding ServerVersion}"
                                IsVisible="{Binding IsServerVersionAvailable}"
                                ToolTip.Tip="Copy plugin version">
							<ui:SymbolIcon Symbol="Copy" FontSize="14" />
						</Button>
					</Grid>

					<!-- Log directory row -->
					<Grid ColumnDefinitions="180,*,28" ColumnSpacing="12" VerticalAlignment="Center">
						<TextBlock Grid.Column="0"
                                   Text="Log directory"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
						<Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8 4">
							<SelectableTextBlock Text="{Binding LogDirPath}"
                                                 FontFamily="Consolas,Courier New,monospace"
                                                 FontSize="11.5" Opacity="0.7" />
						</Border>
						<Button Grid.Column="2"
                                Padding="4"
                                Command="{Binding OpenLogDirCommand}"
                                ToolTip.Tip="Open log directory">
							<ui:SymbolIcon Symbol="Folder" FontSize="14" />
						</Button>
					</Grid>

					<!-- COM Server actions -->
					<Grid ColumnDefinitions="180,*,Auto" ColumnSpacing="12" VerticalAlignment="Center">
						<TextBlock Grid.Column="0"
								   Text="COM Server actions"
								   FontFamily="Consolas,Courier New,monospace"
								   FontSize="12.5" FontWeight="SemiBold"
								   VerticalAlignment="Center" />
						<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
							<Button Content="Register"
									Command="{Binding RegisterCommand}"
									Padding="8 3" FontSize="12" />
							<Button Content="Unregister"
									Command="{Binding UnregisterCommand}"
									Padding="8 3" FontSize="12" />
						</StackPanel>
					</Grid>

                </StackPanel>
            </Border>

            <!-- Log -->
            <ScrollViewer x:Name="LogScrollViewer"
                          MaxHeight="220"
                          Margin="0 18 0 0"
                          HorizontalScrollBarVisibility="Visible"
                          VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock x:Name="LogTextBlock"
                                     Text="{Binding LogText}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="11"
                                     TextWrapping="NoWrap"
                                     Margin="8 6"
                                     GotFocus="LogTextBlock_GotFocus" />
            </ScrollViewer>
        </StackPanel>
    </Expander>
</UserControl>
