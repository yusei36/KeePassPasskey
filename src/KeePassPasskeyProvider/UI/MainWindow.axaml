<ui:AppWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:ui="using:FluentAvalonia.UI.Windowing"
              xmlns:local="using:KeePassPasskeyProvider.UI"
              x:Class="KeePassPasskeyProvider.UI.MainWindow"
              Title="KeePassPasskey"
              Icon="avares://KeePassPasskeyProvider/Resources/app-icon.png"
              Width="650"
              CanResize="False" SizeToContent="Height"
              WindowStartupLocation="CenterScreen">
    <StackPanel Margin="24 24 24 0" Spacing="14">
        <!-- Not-packaged warning -->
        <Border IsVisible="{Binding IsNotPackaged}"
                Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="4" Padding="12 8">
            <TextBlock TextWrapping="Wrap" Foreground="#856404">
                <Run Text="Warning: " FontWeight="Bold" />
                <Run Text="This app is not running from an installed MSIX package. Register and Unregister will not work correctly. Please install the package first." />
            </TextBlock>
        </Border>

        <!-- Status hero -->
        <local:StatusHero DataContext="{Binding StatusHero}" />

        <!-- Setup guide -->
        <local:SetupGuide DataContext="{Binding SetupGuide}" />

        <!-- Diagnostics -->
        <local:Diagnostics DataContext="{Binding Diagnostics}" />
    </StackPanel>
</ui:AppWindow>
