<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="KeePassPasskeyProvider.UI.MainWindow"
        Title="KeePass Passkey Provider"
        Width="550" Height="420"
        CanResize="False"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="24" Spacing="14">
        <TextBlock Text="KeePass Passkey Provider" FontSize="18" FontWeight="Bold" />

        <!-- Not-packaged warning -->
        <Border IsVisible="{Binding IsNotPackaged}"
                Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="4" Padding="12 8">
            <TextBlock TextWrapping="Wrap" Foreground="#856404">
                <Run Text="Warning: " FontWeight="Bold" />
                <Run Text="This app is not running from an installed MSIX package. Register and Unregister will not work correctly. Please install the package first." />
            </TextBlock>
        </Border>

        <!-- Setup guide -->
        <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="1" CornerRadius="4" Padding="12 10">
            <StackPanel Spacing="6">
                <TextBlock Text="Setup" FontWeight="SemiBold" FontSize="16" />

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="1." FontWeight="SemiBold" Width="16" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock VerticalAlignment="Center">
							<Run Text="Click " />
							<Run Text="Register" FontWeight="Bold" />
							<Run Text=" to register the provider with Windows." />
						</TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="2." FontWeight="SemiBold" Width="16" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock Text="Open" VerticalAlignment="Center" />
                        <Button Content="Settings → Accounts → Passkeys"
                                Command="{Binding OpenPasskeySettingsCommand}"
                                Padding="8 2" FontSize="12" />
						<TextBlock TextWrapping="Wrap">
							<Run Text="then navigate to " />
							<Run Text="Advanced Options" FontWeight="Bold" />
						</TextBlock>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="3." FontWeight="SemiBold" Width="16" />
					<TextBlock TextWrapping="Wrap">
						<Run Text="Enable " />
						<Run Text="KeePass Passkey Provider" FontWeight="Bold" />
					</TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="4." FontWeight="SemiBold" Width="16" />
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock VerticalAlignment="Center">
							<Run Text="Status should show " />
							<Run Text="Enabled" FontWeight="Bold" />
						</TextBlock>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status + action row -->
        <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="Status:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Ellipse Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Register"   Command="{Binding RegisterCommand}"   Width="110" HorizontalContentAlignment="Center" />
            <Button Content="Unregister" Command="{Binding UnregisterCommand}" Width="110" HorizontalContentAlignment="Center" />
            <Button Content="Refresh"    Command="{Binding RefreshCommand}"    Width="110" HorizontalContentAlignment="Center" />
        </StackPanel>

        <TextBlock Text="{Binding ResultMessage}" TextWrapping="Wrap" />
    </StackPanel>
</Window>
