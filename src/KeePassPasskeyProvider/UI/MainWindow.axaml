<ui:AppWindow xmlns="https://github.com/avaloniaui"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:ui="using:FluentAvalonia.UI.Windowing"
              xmlns:local="using:KeePassPasskeyProvider.UI"
              x:Class="KeePassPasskeyProvider.UI.MainWindow"
                 Title="KeePassPasskey"
                 Icon="avares://KeePassPasskeyProvider/Resources/app-icon.png"
                 Width="650" MinHeight="350" MaxHeight="800"
                 CanResize="False" SizeToContent="Height"
                 WindowStartupLocation="CenterScreen">
    <StackPanel Margin="24" Spacing="14">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <TextBlock Text="KeePassPasskey" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
            <TextBlock Text="{Binding AppVersion}" FontSize="13" Opacity="0.55" VerticalAlignment="Center" />
        </StackPanel>
        <TextBlock Text="Windows passkey provider · requires KeePassPasskey installed in KeePass"
                   FontSize="11" Opacity="0.55" Margin="0 -8 0 0" />

        <!-- Not-packaged warning -->
        <Border IsVisible="{Binding IsNotPackaged}"
                Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                CornerRadius="4" Padding="12 8">
            <TextBlock TextWrapping="Wrap" Foreground="#856404">
                <Run Text="Warning: " FontWeight="Bold" />
                <Run Text="This app is not running from an installed MSIX package. Register and Unregister will not work correctly. Please install the package first." />
            </TextBlock>
        </Border>

        <!-- Setup guide -->
        <local:SetupGuide />

        <!-- Status rows -->
        <Grid ColumnDefinitions="160,18,Auto" RowDefinitions="Auto,Auto">
			<TextBlock Grid.Row="0" Grid.Column="0" Text="KeePass plugin status:" FontWeight="SemiBold" VerticalAlignment="Center" />
			<Ellipse   Grid.Row="0" Grid.Column="1" Width="10" Height="10" Fill="{Binding PluginStatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
			<TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding PluginStatusText}" VerticalAlignment="Center" />
			
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Passkey provider status:" FontWeight="SemiBold" VerticalAlignment="Center" />
            <Ellipse   Grid.Row="1" Grid.Column="1" Width="10" Height="10" Fill="{Binding StatusColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding StatusText}" VerticalAlignment="Center" />
        </Grid>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Register"   Command="{Binding RegisterCommand}"   Width="110" HorizontalContentAlignment="Center" />
            <Button Content="Unregister" Command="{Binding UnregisterCommand}" Width="110" HorizontalContentAlignment="Center" />
            <Button Content="Refresh"    Command="{Binding RefreshCommand}"    Width="110" HorizontalContentAlignment="Center" />
        </StackPanel>

        <TextBlock Text="{Binding ResultMessage}" TextWrapping="Wrap" />

        <!-- Log viewer -->
        <Expander Header="Log" IsExpanded="{Binding IsLogVisible, Mode=TwoWay}">
            <ScrollViewer x:Name="LogScrollViewer"
                          MaxHeight="220"
                          HorizontalScrollBarVisibility="Visible"
                          VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock x:Name="LogTextBlock"
                                     Text="{Binding LogText}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="11"
                                     TextWrapping="NoWrap"
                                     Margin="8 6"
                                     GotFocus="LogTextBlock_GotFocus" />
            </ScrollViewer>
        </Expander>
    </StackPanel>
</ui:AppWindow>
