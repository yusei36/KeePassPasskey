<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="using:KeePassPasskeyProvider.Converters"
             xmlns:vm="using:KeePassPasskeyProvider.ViewModels"
             x:Class="KeePassPasskeyProvider.UI.StatusHero">
    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="8">
        <StackPanel>

            <!-- Summary row: ring + headline (left), pills (right) -->
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16" Margin="18 16 18 14">

                <!-- Left: ring + text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="22" BorderThickness="1.5" VerticalAlignment="Center"
                            BorderBrush="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.RingBorderBrush}}"
                            Background="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.RingBackgroundBrush}}">
                        <Grid>
                            <Path Data="M3 8.5 L6.5 12 L13 4.5"
                                  Stroke="White" StrokeThickness="1.6"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Width="16" Height="16" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  IsVisible="{Binding Status, Converter={x:Static conv:EnumEqualsConverter.Instance}, ConverterParameter={x:Static vm:ProviderStatus.Ready}}" />
                            <Path Data="M8 1.5 L14.5 13.5 L1.5 13.5 Z M8 6 L8 9.2 M8 11.2 L8 11.8"
                                  Stroke="White" StrokeThickness="1.25"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Width="16" Height="16" Stretch="Uniform"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"
                                  IsVisible="{Binding Status, Converter={x:Static conv:EnumEqualsConverter.Negated}, ConverterParameter={x:Static vm:ProviderStatus.Ready}}" />
                        </Grid>
                    </Border>

                    <StackPanel VerticalAlignment="Center" Spacing="3">
                        <TextBlock FontSize="18" FontWeight="SemiBold"
                                   Text="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.Headline}}" />
                        <TextBlock FontSize="12.5" Opacity="0.6" MaxWidth="280" TextWrapping="Wrap"
                                   Text="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.Subhead}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Right: status pills -->
                <Grid Grid.Column="1"
                      ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto"
                      ColumnSpacing="14" RowSpacing="6"
                      VerticalAlignment="Center">

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="KeePass plugin" FontSize="12.5" Opacity="0.6" VerticalAlignment="Center" />
                    <Border Grid.Row="0" Grid.Column="1"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="999" Padding="8 2 10 2">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{Binding PluginStatus, Converter={x:Static conv:PingStatusConverters.DotColor}}" />
                            <TextBlock FontSize="12" FontWeight="Medium" VerticalAlignment="Center"
                                       Text="{Binding PluginStatus, Converter={x:Static conv:PingStatusConverters.Text}}" />
                        </StackPanel>
                    </Border>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Passkey provider" FontSize="12.5" Opacity="0.6" VerticalAlignment="Center" />
                    <Border Grid.Row="1" Grid.Column="1"
                            Background="{DynamicResource ControlFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="999" Padding="8 2 10 2">
                        <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                     Fill="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.ProviderDotColor}}" />
                            <TextBlock FontSize="12" FontWeight="Medium" VerticalAlignment="Center"
                                       Text="{Binding Status, Converter={x:Static conv:ProviderStatusConverters.ProviderPillText}}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- Divider -->
            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Opacity="0.5" />

            <!-- Action row -->
            <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="8" Margin="18 12 18 14">
                <Button Grid.Column="0" Content="Refresh status" Command="{Binding RefreshCommand}" />
                <Button Grid.Column="1" Content="Register"   Command="{Binding RegisterCommand}"   IsVisible="{Binding CanRegister}" />
                <Button Grid.Column="1" Content="Unregister" Command="{Binding UnregisterCommand}" IsVisible="{Binding CanUnregister}" />
                <Button Grid.Column="3" Content="Open passkey settings" Command="{Binding OpenPasskeySettingsCommand}" IsVisible="{Binding ShowOpenPasskeySettings}" />
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
