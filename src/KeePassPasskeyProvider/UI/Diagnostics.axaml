<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="KeePassPasskeyProvider.UI.Diagnostics">
    <Expander IsExpanded="{Binding IsLogVisible, Mode=TwoWay}">
        <Expander.Header>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Diagnostics" FontWeight="SemiBold" FontSize="14" VerticalAlignment="Center" />
                <TextBlock Text="Version mismatch" FontSize="12" Foreground="#fce100" VerticalAlignment="Center"
                           IsVisible="{Binding IsVersionMismatch}" />
            </StackPanel>
        </Expander.Header>

        <StackPanel>
            <!-- Versions strip -->
            <Border Padding="14 12"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="0 0 0 1">
                <StackPanel Spacing="6">
                    <!-- Provider version row -->
                    <Grid ColumnDefinitions="180,*,28" ColumnSpacing="12" VerticalAlignment="Center">
                        <TextBlock Grid.Column="0"
                                   Text="KeePassPasskeyProvider"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8 4">
                            <TextBlock Text="{Binding ClientVersionShort}"
                                       FontFamily="Consolas,Courier New,monospace"
                                       FontSize="11.5" Opacity="0.7" />
                        </Border>
                        <Button Grid.Column="2"
                                Padding="6"
                                Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding ClientVersion}"
                                ToolTip.Tip="Copy provider version">
                            <Path Data="M 6 2.5 H 12 A 1 1 0 0 1 13 3.5 V 11.5 A 1 1 0 0 1 12 12.5 H 6 A 1 1 0 0 1 5 11.5 V 3.5 A 1 1 0 0 1 6 2.5 Z M 10 12.5 V 13.5 A 0.5 0.5 0 0 1 9.5 14 H 3.5 A 0.5 0.5 0 0 1 3 13.5 V 5 A 0.5 0.5 0 0 1 3.5 4.5 H 5"
                                  Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                  StrokeThickness="1.2" StrokeJoin="Round" StrokeLineCap="Round"
                                  Width="13" Height="13" Stretch="Uniform" />
                        </Button>
                    </Grid>

					<!-- Plugin version row -->
					<Grid ColumnDefinitions="180,*,28" ColumnSpacing="12" VerticalAlignment="Center">
						<TextBlock Grid.Column="0"
                                   Text="KeePassPasskeyPlugin"
                                   FontFamily="Consolas,Courier New,monospace"
                                   FontSize="12.5" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
						<Border Grid.Column="1"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="4" Padding="8 4">
							<Panel>
								<TextBlock Text="{Binding ServerVersionShort}"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="11.5" Opacity="0.7"
                                           IsVisible="{Binding IsServerVersionAvailable}" />
								<TextBlock Text="not running"
                                           FontFamily="Consolas,Courier New,monospace"
                                           FontSize="11.5" Opacity="0.35"
                                           IsVisible="{Binding IsServerVersionNotAvailable}" />
							</Panel>
						</Border>
						<Button Grid.Column="2"
                                Padding="6"
                                Command="{Binding CopyToClipboardCommand}"
                                CommandParameter="{Binding ServerVersion}"
                                IsVisible="{Binding IsServerVersionAvailable}"
                                ToolTip.Tip="Copy plugin version">
							<Path Data="M 6 2.5 H 12 A 1 1 0 0 1 13 3.5 V 11.5 A 1 1 0 0 1 12 12.5 H 6 A 1 1 0 0 1 5 11.5 V 3.5 A 1 1 0 0 1 6 2.5 Z M 10 12.5 V 13.5 A 0.5 0.5 0 0 1 9.5 14 H 3.5 A 0.5 0.5 0 0 1 3 13.5 V 5 A 0.5 0.5 0 0 1 3.5 4.5 H 5"
                                  Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                                  StrokeThickness="1.2" StrokeJoin="Round" StrokeLineCap="Round"
                                  Width="13" Height="13" Stretch="Uniform" />
						</Button>
					</Grid>

					<!-- Version mismatch warning -->
                    <Border IsVisible="{Binding IsVersionMismatch}"
                            Background="#433519"
                            BorderBrush="#fce10040" BorderThickness="1"
                            CornerRadius="4" Padding="10 8" Margin="0 4 0 0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Data="M8 1.5 L14.5 13.5 L1.5 13.5 Z M8 6 L8 9.2 M8 11.2 L8 11.8"
                                  Stroke="#fce100" StrokeThickness="1.25"
                                  StrokeLineCap="Round" StrokeJoin="Round"
                                  Width="14" Height="14" Stretch="Uniform"
                                  VerticalAlignment="Top" Margin="0 1 0 0" />
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#fce100"
                                       Text="Plugin and provider versions don't match. Reinstall either the plugin or the app so both are the same." />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

            <!-- Log -->
            <ScrollViewer x:Name="LogScrollViewer"
                          MaxHeight="220"
                          HorizontalScrollBarVisibility="Visible"
                          VerticalScrollBarVisibility="Auto">
                <SelectableTextBlock x:Name="LogTextBlock"
                                     Text="{Binding LogText}"
                                     FontFamily="Consolas,Courier New,monospace"
                                     FontSize="11"
                                     TextWrapping="NoWrap"
                                     Margin="8 6"
                                     GotFocus="LogTextBlock_GotFocus" />
            </ScrollViewer>
        </StackPanel>
    </Expander>
</UserControl>
